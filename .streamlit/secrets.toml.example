# Streamlit secrets template.
#
# LOCAL: copy this file to `.streamlit/secrets.toml` and fill in real values.
#        (.streamlit/secrets.toml is gitignored and must never be committed.)
#
# STREAMLIT CLOUD: do NOT commit secrets. After deploying, open your app's
#        Settings -> Secrets and paste the same key/value lines there.

FP_API_KEY = "your_firstpromoter_api_key"
FP_ACCOUNT_ID = "your_account_id"

# Optional overrides:
FP_THRESHOLD_DAYS = "90"
FP_CURRENCY = "$"

# Optional password gate. If set, viewers must enter this to see the dashboard.
# Leave it out to keep the app fully open to anyone with the link.
# APP_PASSWORD = "choose-a-strong-password"
